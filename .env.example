# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# JWT / security
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_SETUP_KEY=replace-with-a-private-admin-bootstrap-key

# CORS
# Add your deployed frontend URL when available, for example:
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend.example.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/google/callback

# Optional. Leave blank while no frontend exists; callback returns JSON directly.
FRONTEND_AUTH_SUCCESS_URL=
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
